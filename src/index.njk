---
layout: base.njk
---

{% set posts = collections.blogs %}

<section class="relative min-h-[50vh] flex items-center">
  <div class="absolute inset-0 grid-pattern opacity-60"></div>
  <div class="container relative mx-auto px-4 py-16">
    <div class="max-w-4xl mx-auto text-center animate-fade-in-up">
      <h1 class="text-4xl md:text-6xl font-bold text-bleu-950 mb-6">
        {{ t("home:hero.title", locale) }}
      </h1>
      {% if locale == "ar" %}
      <p class="text-sm md:text-base font-medium tracking-[0.22em] uppercase text-bleu-500 mb-5" dir="ltr">
        {{ t("home:hero.originalTitle", locale) }}
      </p>
      {% endif %}
      <p class="text-xl text-bleu-700 mb-8 max-w-2xl mx-auto">
        {{ t("home:hero.description", locale) }}
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="{{ localeUrl('/blogs/', locale) }}" class="btn btn-primary text-lg px-8 py-3">
          <span class="btn-label">{{ t("home:hero.browseBlogs", locale) }}</span>
        </a>
        <a href="{{ localeUrl('/contributing/', locale) }}" class="btn btn-secondary text-lg px-8 py-3">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          <span class="btn-label">{{ t("home:hero.contribute", locale) }}</span>
        </a>
      </div>
    </div>
  </div>
</section>

<section class="py-8">
  <div class="max-w-4xl mx-auto px-4">
    {% include "components/discord-widget.njk" %}
  </div>
</section>

<section class="py-12">
  <div class="max-w-6xl mx-auto px-4">
    <div class="flex items-center justify-between mb-8 gap-4">
      <h2 class="text-2xl md:text-3xl font-bold text-bleu-950">{{ t("home:latestPosts.title", locale) }}</h2>
      <a href="{{ localeUrl('/blogs/', locale) }}" class="text-bleu-600 hover:text-bleu-700 font-medium">
        {{ t("home:latestPosts.viewAll", locale) }}
      </a>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {% for post in posts | limit(6) %}
        {% include "components/blog-card.njk" %}
      {% else %}
        <div class="col-span-full text-center py-12">
          <p class="text-bleu-700 text-lg mb-4">{{ t("home:latestPosts.emptyTitle", locale) }}</p>
          <a href="{{ localeUrl('/contributing/', locale) }}" class="btn btn-primary">
            <span class="btn-label">{{ t("home:latestPosts.submitBlog", locale) }}</span>
          </a>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<section class="py-12 bg-bleu-50/50">
  <div class="max-w-4xl mx-auto px-4 text-center">
    <h2 class="text-2xl md:text-3xl font-bold text-bleu-950 mb-4">{{ t("home:openSource.title", locale) }}</h2>
    <p class="text-bleu-700 mb-8 max-w-2xl mx-auto">
      {{ t("home:openSource.description", locale) }}
    </p>
    <div class="grid md:grid-cols-3 gap-6 text-start">
      <div class="card">
        <div class="text-3xl mb-2 font-bold text-bleu-800">1</div>
        <h3 class="font-bold text-bleu-950 mb-2">{{ t("home:openSource.steps.write.title", locale) }}</h3>
        <p class="text-bleu-700 text-sm">{{ t("home:openSource.steps.write.description", locale) }}</p>
      </div>
      <div class="card">
        <div class="text-3xl mb-2 font-bold text-bleu-800">2</div>
        <h3 class="font-bold text-bleu-950 mb-2">{{ t("home:openSource.steps.pr.title", locale) }}</h3>
        <p class="text-bleu-700 text-sm">{{ t("home:openSource.steps.pr.description", locale) }}</p>
      </div>
      <div class="card">
        <div class="text-3xl mb-2 font-bold text-bleu-800">3</div>
        <h3 class="font-bold text-bleu-950 mb-2">{{ t("home:openSource.steps.publish.title", locale) }}</h3>
        <p class="text-bleu-700 text-sm">{{ t("home:openSource.steps.publish.description", locale) }}</p>
      </div>
    </div>
  </div>
</section>
