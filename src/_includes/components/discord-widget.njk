<div class="card bg-gradient-to-br from-[#5865F2] to-[#4752C4] text-white border-none">
  <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
    <div class="flex items-center gap-4">
      <span class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-white/95">
        <img src="/assets/images/icons/discord.svg" alt="Discord" class="w-8 h-8">
      </span>
      <div class="text-start">
        <div class="font-bold text-lg">{{ t("home:discord.title", locale) }}</div>
        <div class="text-white/80 text-sm">
          <span class="font-semibold">{{ discord.members }}</span> {{ t("home:discord.members", locale) }} •
          <span class="font-semibold text-green-300">{{ discord.online }}</span> {{ t("home:discord.online", locale) }}
        </div>
      </div>
    </div>
    <a
      href="{{ site.discord.invite }}"
      target="_blank"
      rel="noopener"
      class="btn bg-white text-[#5865F2] hover:bg-bleu-50 font-bold"
    >
      <span class="btn-label">{{ t("home:discord.joinServer", locale) }}</span>
    </a>
  </div>
</div>
