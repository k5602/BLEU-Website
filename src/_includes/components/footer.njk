<footer class="border-t border-bleu-100 bg-white py-12">
  <div class="max-w-6xl mx-auto px-4">
    <div class="flex flex-col md:flex-row justify-between items-center md:items-start gap-8">
      <div class="flex items-center gap-3">
        <img src="/assets/images/logo.svg" alt="BLEU" class="w-10 h-10 rounded">
        <div>
          <div class="font-semibold text-bleu-950">BLEU Community</div>
          <div class="text-sm text-bleu-600">{{ t("common:site.tagline", locale) }}</div>
        </div>
      </div>

      <div class="flex flex-wrap justify-center gap-8 md:gap-12">
        <div class="flex flex-col gap-2 text-center md:text-start">
          <span class="font-semibold text-bleu-950 text-sm uppercase tracking-wide">{{ t("common:footer.content", locale) }}</span>
          <a href="{{ localeUrl('/blogs/', locale) }}" class="text-bleu-700 hover:text-bleu-900 text-sm">{{ t("common:footer.allBlogs", locale) }}</a>
          <a href="{{ localeUrl('/contributing/', locale) }}" class="text-bleu-700 hover:text-bleu-900 text-sm">{{ t("common:footer.submitBlog", locale) }}</a>
        </div>

        <div class="flex flex-col gap-2 text-center md:text-start">
          <span class="font-semibold text-bleu-950 text-sm uppercase tracking-wide">{{ t("common:footer.community", locale) }}</span>
          <a href="{{ site.discord.invite }}" target="_blank" rel="noopener" class="inline-flex items-center justify-center md:justify-start gap-2 text-bleu-700 hover:text-bleu-900 text-sm">
            Discord
          </a>
          <a href="{{ site.social.twitter }}" target="_blank" rel="noopener" class="inline-flex items-center justify-center md:justify-start gap-2 text-bleu-700 hover:text-bleu-900 text-sm">
            Twitter
          </a>
          <a href="{{ site.social.linkedin }}" target="_blank" rel="noopener" class="inline-flex items-center justify-center md:justify-start gap-2 text-bleu-700 hover:text-bleu-900 text-sm">
            LinkedIn
          </a>
        </div>

        <div class="flex flex-col gap-2 text-center md:text-start">
          <span class="font-semibold text-bleu-950 text-sm uppercase tracking-wide">{{ t("common:footer.openSource", locale) }}</span>
          <a href="https://github.com/{{ site.repo }}" target="_blank" rel="noopener" class="text-bleu-700 hover:text-bleu-900 text-sm">GitHub</a>
          <a href="https://github.com/{{ site.repo }}/issues" target="_blank" rel="noopener" class="text-bleu-700 hover:text-bleu-900 text-sm">{{ t("common:footer.issues", locale) }}</a>
        </div>
      </div>
    </div>

    <div class="mt-8 pt-8 border-t border-bleu-100 text-center text-bleu-700 text-sm">
      {{ t("common:footer.copyright", locale) }}
    </div>
  </div>
</footer>
