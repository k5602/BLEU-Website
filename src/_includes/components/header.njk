<header class="sticky top-0 z-50 w-full border-b border-bleu-200/70 bg-white/80 backdrop-blur supports-[backdrop-filter]:bg-white/60">
  <div class="max-w-6xl mx-auto px-4 py-4">
    <nav class="flex items-center justify-between gap-4">
      <a href="{{ localeUrl('/', locale) }}" class="flex items-center gap-3 hover:opacity-80 transition-opacity">
        <img src="/assets/images/logo.svg" alt="BLEU" class="w-10 h-10 rounded">
        <div>
          <div class="text-base font-semibold text-bleu-950">{{ t("common:site.communityLabel", locale) }}</div>
          <div class="text-[11px] text-bleu-600">{{ t("common:site.tagline", locale) }}</div>
        </div>
      </a>

      <div class="hidden md:flex items-center gap-4 lg:gap-6">
        <a href="{{ localeUrl('/blogs/', locale) }}" class="text-sm text-bleu-700 hover:text-bleu-900 font-medium">{{ t("common:nav.blogs", locale) }}</a>
        <a href="{{ site.discord.invite }}" target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-sm text-bleu-700 hover:text-bleu-900 font-medium">
          <img src="/assets/images/icons/discord.svg" alt="" class="w-4 h-4" aria-hidden="true">
          {{ t("common:nav.joinDiscord", locale) }}
        </a>
        <a href="{{ localeUrl('/contributing/', locale) }}" class="btn btn-primary text-sm">
          <svg class="size-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          <span class="btn-label">{{ t("common:nav.contribute", locale) }}</span>
        </a>
        <select class="lang-switcher" aria-label="{{ t('common:nav.languageSwitcher', locale) }}">
          <option value="{{ localeUrl(page.url, 'ar') }}" {% if locale == 'ar' %}selected{% endif %}>{{ t("common:language.arabic", locale) }}</option>
          <option value="{{ localeUrl(page.url, 'en') }}" {% if locale == 'en' %}selected{% endif %}>{{ t("common:language.english", locale) }}</option>
        </select>
      </div>

      <button
        class="md:hidden p-2 text-bleu-700 hover:bg-bleu-50 rounded-lg"
        onclick="document.getElementById('mobile-menu').classList.toggle('hidden')"
        aria-label="{{ t('common:nav.toggleMenu', locale) }}"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </nav>

    <nav id="mobile-menu" class="hidden md:hidden mt-4 pb-4 border-t border-bleu-100 pt-4">
      <div class="flex flex-col gap-4">
        <a href="{{ localeUrl('/blogs/', locale) }}" class="text-bleu-700 hover:text-bleu-900 font-medium">{{ t("common:nav.blogs", locale) }}</a>
        <a href="{{ site.discord.invite }}" target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-bleu-700 hover:text-bleu-900 font-medium">
          <img src="/assets/images/icons/discord.svg" alt="" class="w-4 h-4" aria-hidden="true">
          {{ t("common:nav.joinDiscord", locale) }}
        </a>
        <a href="{{ localeUrl('/contributing/', locale) }}" class="text-bleu-700 hover:text-bleu-900 font-medium">{{ t("common:nav.contribute", locale) }}</a>
        <select class="lang-switcher" aria-label="{{ t('common:nav.languageSwitcher', locale) }}">
          <option value="{{ localeUrl(page.url, 'ar') }}" {% if locale == 'ar' %}selected{% endif %}>{{ t("common:language.arabic", locale) }}</option>
          <option value="{{ localeUrl(page.url, 'en') }}" {% if locale == 'en' %}selected{% endif %}>{{ t("common:language.english", locale) }}</option>
        </select>
      </div>
    </nav>
  </div>
</header>
